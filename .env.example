# ─── LLM ─────────────────────────────────────────────────────────────────────
# Provider: google | anthropic | openai
LLM_PROVIDER=google

# Model name — must match the provider:
#   google:    gemini-2.5-flash-lite  (free tier, recommended)
#   anthropic: claude-haiku-4-5-20251001
#   openai:    gpt-4o-mini
LLM_MODEL=gemini-2.5-flash-lite

# API keys — set only the one matching your LLM_PROVIDER
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Demo user credentials (seeded on first startup)
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo1234

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Local:      sqlite:///./data/market_research.db
# Production: sqlite:////app/data/market_research.db  (Azure File Share mount)
DATABASE_URL=sqlite:///./data/market_research.db

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Local:      http://localhost:5173
# Production: https://<your-app>.azurestaticapps.net
ALLOWED_ORIGINS=http://localhost:5173

# ─── APP ──────────────────────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
ENABLE_DOCS=true

# ─── PIPELINE TUNING (see docs/adr/ADR-005-pipeline-performance.md) ──────────
PIPELINE_MAX_ARTICLE_CHARS=3000
PIPELINE_MAX_SOURCE_CHARS=2000
PIPELINE_MAX_JUDGE_CLAIMS=3
PIPELINE_MAX_THEMES=2
PIPELINE_MAX_COMPETITOR_ACTIVITIES=2
# Confidence threshold to flag a verdict as hallucination (0.0–1.0)
# Higher = more liberal (fewer flags). Lower = stricter (more flags).
PIPELINE_HALLUCINATION_THRESHOLD=0.8